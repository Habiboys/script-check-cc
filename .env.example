# --- Spreadsheet terpisah (disarankan) ---
# ID spreadsheet form responses (baca data mahasiswa)
INPUT_SPREADSHEET_ID=

# ID spreadsheet hasil checker (tulis output)
RESULT_SPREADSHEET_ID=

# Fallback: jika INPUT/RESULT tidak diisi, keduanya pakai ID ini (satu file)
# SPREADSHEET_ID=

# Nama tab di spreadsheet input (default Google Forms: "Form Responses 1")
INPUT_SHEET_NAME=Form Responses 1

# Nama tab di spreadsheet output
RESULT_SHEET_NAME=Hasil Checker

# Path ke file JSON service account (lokal saja; GitHub Actions pakai GOOGLE_CREDENTIALS)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Atau paste seluruh JSON service account sebagai string (untuk GitHub Actions)
# GOOGLE_CREDENTIALS={"type":"service_account",...}
